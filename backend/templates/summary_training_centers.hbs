<style type="text/css">

figure table {
  border : 1px solid black;
  border-collapse: collapse;
}

.table tr td{
  border : 1px solid black;
}

.table tr td{
  font-weight: lighter;
}

body{
    font-family: 'Arial Narrow';
    margin : 0;
    padding : 0;
}

table {
    width: 100%;
}

table tr td {
    padding: 2px 4px 2px 4px;
}

.header {
    {{!-- font-size: 20px; --}}
}

.no_border_table td{
    border: none;
    font-weight: bold;
    font-size: 14px;
    word-wrap: break-word;
    word-break: break-word;
}

.border_table td{
    border: 1px solid black;
    font-weight: bold;
    font-size: 14px;
    word-wrap: break-word;
    word-break: break-word;
}

.no_border_table{
    padding: 0;
    width: 100%;
}

.border_table{
    border-collapse: collapse;
    border: 1px solid black;
    padding: 0;
    width: 100%;
}

.border_table th{
    text-align: start;
    padding: 2px;
    font-size: 14px;
    border: 1px solid black;
}

img {
    height: auto;
    width: 100%;
}

.page-footer img {
    height: auto;
    width: 100%;
}

.main_table, .main_table thead, .main_table tbody, .main_table tfoot {
    border: none;
}

.page-header-space {
  height: 70px;
  width: 100%;
  padding: 5px;
}

.page-footer-space {
  height: 100px;
  width: 100%;
}

.page-footer {
  height: auto;
  width: 100%;
}

.page-footer {
  position: fixed;
  bottom: 0;
  width: 100%;
}

.page-header {
  position: fixed;
  top: 0mm;
  height: 85px;
  width: 100%;
  padding: 5px;
}

.page-footer img {
  max-height: 95px;
  height: auto;
  width: 100%;
  object-fit: contain;
}

.page-header img {
  max-height: 95px;
  height: 100%;
  width: 100%;
  object-fit: cover;
 
  
}

.page {
  page-break-after: auto;
  padding: 0px 50px 0px 50px;
}

tr.spaceUnder>td {
  padding-bottom: 1em;
}

.content_body {
    height: 100%;
}

h1 {
            font-size: 24px;
            margin-top: 10px;
            text-align: center;
        }

        h2 {
            font-size: 20px;
            margin-top: 5px;
            text-align: center;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 30px;
            page-break-inside: auto;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            font-size: 12px;
        }

        th {
            background-color: #f2f2f2;
        }

        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }


@media print {
    table { page-break-after:auto }
    th    { page-break-inside:avoid; page-break-after:auto }
  tr    { page-break-inside:avoid; page-break-after:auto }
  td    { page-break-inside:avoid; page-break-after:auto }
   thead {display: table-header-group;} 
   tfoot {display: table-footer-group;}

   
}


</style>
<html>
    <body>

        <div class="page-header">
            <img src="data:image/png;base64,">
        </div>

        <div class="page-footer">
          <img src="data:image/png;base64,"/>
        </div>



        <table class="main_table">

    <thead>
      <tr>
        <td>
          <div class="page-header-space">
                
          </div>
        </td>
      </tr>
    </thead>

    <tbody>
      <tr>
        <td>
          <div class="page">

            <div class="content_body">

            <center>
                <h1>Registered Training Programs in TESDA Davao de Oro</h1>
            </center>
        
            {{#each summaryData}}
              <!-- Training Center Name -->
              <h2 style="text-align:left; margin-top:30px;">
                {{trainingCenter}}
              </h2>

              <!-- Qualifications Table -->
              <table class="border_table">
                <thead>
                  <tr>
                    <th style="width:70%;">Qualification</th>
                    <th style="width:30%;">Duration (Hours)</th>
                  </tr>
                </thead>

                <tbody>
                  {{#each qualifications}}
                    <tr>
                      <td>{{qualification}}</td>
                      <td style="text-align:center;">{{duration}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            {{/each}}



            </div>

          </div>
          
          
        </td>
      </tr>
    </tbody>

  

    <tfoot>
      <tr>
        <td>
          <div class="page-footer-space">
                
          </div>
        </td>
      </tr>
    </tfoot>

  </table>


        
    </body>
</html>