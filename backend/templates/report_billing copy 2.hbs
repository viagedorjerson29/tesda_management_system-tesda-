<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
        }

        /* =========================================== */
        /* FIX: PAGE MARGINS (RESERVE SPACE FOR HEADER/FOOTER) */
        /* =========================================== */
        @page {
            margin: 150px 30px 100px;
        }

        /* =========================================== */
        /* FIX: REPEATING HEADER */
        /* =========================================== */
        header {
            position: fixed;
            top: -120px;
            left: 0;
            right: 0;
            height: 110px;
            padding: 10px 20px;
            border-bottom: 1px solid #ccc;
            text-align: left;
            running: header;
        }

        header img {
            height: 80px;
        }

        /* =========================================== */
        /* FIX: REPEATING FOOTER */
        /* =========================================== */
        footer {
            position: fixed;
            bottom: -80px;
            left: 0;
            right: 0;
            height: 70px;
            border-top: 1px solid #ccc;
            text-align: center;
            padding-top: 5px;
            font-size: 12px;
            running: footer;
        }

        footer img {
            height: 40px;
        }

        @page {
            @top-center {
                content: element(header);
            }
            @bottom-center {
                content: element(footer);
            }
        }

        /* =========================================== */
        /* CONTENT */
        /* =========================================== */
        h1 {
            font-size: 24px;
            margin-top: 10px;
            text-align: center;
        }

        h2 {
            font-size: 20px;
            margin-top: 5px;
            text-align: center;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 30px;
            page-break-inside: auto;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            font-size: 12px;
        }

        th {
            background-color: #f2f2f2;
        }

        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }
    </style>
</head>
<body>

<!-- ===================== REPEATING HEADER ======================= -->
<header>
    <img src="data:image/png;base64," alt="Header Logo">
</header>

<!-- ===================== REPEATING FOOTER ======================= -->
<footer>
    <div>
        <img src="data:image/png;base64," alt="Footer Logo">
    </div>
    <div>{{footerText}} — Page {{pageNumber}} of {{totalPages}}</div>
</footer>

<!-- ===================== MAIN CONTENT ======================= -->

<h1>{{title_report}}</h1>
<h2>{{title}}</h2>

{{#if type}}

    <!-- ===================== BILLING REPORT ======================= -->
    {{#eq type 'billing_report'}}
    <table>
        <thead>
            <tr>
                {{#if hasTC}}<th>Training Center</th>{{/if}}
                <th>RQM CODE</th>
                <th>Scholarship Type</th>
                <th>Training Program</th>
                <th>Billing Type</th>
                <th>Submission Date</th>
                <th>Status</th>
                <th>Total Amount</th>
            </tr>
        </thead>
        <tbody>
            {{#each billingReportData}}
            <tr>
                {{#if ../hasTC}}<td>{{trainingCenter}}</td>{{/if}}
                <td>{{pqmCode}}</td>
                <td>{{scholarshipType}}</td>
                <td>{{trainingProgram}}</td>
                <td>{{billingType}}</td>
                <td>{{submissionDate}}</td>
                <td>{{status}}</td>
                <td>{{peso totalAmount}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/eq}}

    <!-- ===================== UTILIZATION REPORT ======================= -->
    {{#eq type 'utilization_report'}}
    <table>
        <thead>
            <tr>
                {{#if hasTC}}
                    <th>Training Center</th>
                    <th>Allocated Budget</th>
                    <th>Utilized Budget</th>
                    <th>Utilization Rate (%)</th>
                {{else}}
                    <th>RQM Code</th>
                    <th>Scholarship</th>
                    <th>Allocated Budget</th>
                    <th>Utilized Budget</th>
                    <th>Utilization Rate (%)</th>
                {{/if}}
            </tr>
        </thead>
        <tbody>
            {{#each billingReportData}}
            <tr>
                {{#if ../hasTC}}
                    <td>{{trainingCenter}}</td>
                    <td>{{peso allocatedBudget}}</td>
                    <td>{{peso utilizedBudget}}</td>
                    <td>{{utilizationRate}}</td>
                {{else}}
                    <td>{{ctrlNum}}</td>
                    <td>{{scholarshipProgram}}</td>
                    <td>{{peso allocatedBudget}}</td>
                    <td>{{peso utilizedBudget}}</td>
                    <td>{{utilizationRate}}</td>
                {{/if}}
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/eq}}

    <!-- ===================== COMPLIANCE REPORT ======================= -->
    {{#eq type 'compliance_report'}}
    <table>
        <thead>
            <tr>
                {{#if hasTC}}
                    <th>Training Center</th>
                    <th>Number of Billable Submissions</th>
                    <th>On-Time/Correct Submissions</th>
                    <th>Compliance Rate</th>
                {{else}}
                    <th>RQM Code</th>
                    <th>Scholarship</th>
                    <th>Number of Billable Submissions</th>
                    <th>On-Time/Correct Submissions</th>
                    <th>Compliance Rate</th>
                {{/if}}
            </tr>
        </thead>
        <tbody>
            {{#each billingReportData}}
            <tr>
                {{#if ../hasTC}}
                    <td>{{trainingCenter}}</td>
                    <td>{{totalSubmissions}}</td>
                    <td>{{onTimeSubmissions}}</td>
                    <td>{{complianceRate}}%</td>
                {{else}}
                    <td>{{ctrlNum}}</td>
                    <td>{{scholarshipProgram}}</td>
                    <td>{{totalSubmissions}}</td>
                    <td>{{onTimeSubmissions}}</td>
                    <td>{{complianceRate}}%</td>
                {{/if}}
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/eq}}

    <!-- ===================== ASSESSMENT REPORT ======================= -->
    {{#eq type 'assessment_report'}}
    <table>
        <thead>
            <tr>
                {{#if hasTC}}<th>Training Center</th>{{/if}}
                <th>RQM Code</th>
                <th>Qualification</th>
                <th>Competent</th>
                <th>Rate (%)</th>
                <th>NYC</th>
                <th>Rate (%)</th>
                <th>Absent</th>
                <th>Rate (%)</th>
            </tr>
        </thead>
        <tbody>
            {{#each billingReportData}}
            <tr>
                {{#if ../hasTC}}<td>{{trainingCenter}}</td>{{/if}}
                <td>{{ctrlNum}}</td>
                <td>{{qualification}}</td>
                <td>{{competent}}</td>
                <td>{{rateCompetent}}</td>
                <td>{{nyc}}</td>
                <td>{{rateNyc}}</td>
                <td>{{absent}}</td>
                <td>{{rateAbsent}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/eq}}

    <!-- ===================== DROPPED REPORT ======================= -->
    {{#eq type 'dropped_report'}}
    <table>
        <thead>
            <tr>
                <th>No.</th>
                <th>Name</th>
                {{#if hasTC}}<th>Training Center</th>{{/if}}
                <th>RQM Code</th>
                <th>Qualification</th>
            </tr>
        </thead>
        <tbody>
            {{#each billingReportData}}
            <tr>
                <td>{{no}}</td>
                <td>{{name}}</td>
                {{#if ../hasTC}}<td>{{trainingCenter}}</td>{{/if}}
                <td>{{pqmCode}}</td>
                <td>{{qualification}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/eq}}

    <!-- ===================== PERFORMANCE REPORT ======================= -->
    {{#eq type 'performance_report'}}
    <table>
        <thead>
            <tr>
                <th>Rank</th>
                <th>Training Center</th>
                <th>Budget Utilization Rate (BUR)</th>
                <th>Billing Submission Compliance (BSC)</th>
                <th>WPS</th>
            </tr>
        </thead>
        <tbody>
            {{#each billingReportData}}
            <tr>
                <td>{{rank}}</td>
                <td>{{trainingCenter}}</td>
                <td>{{BUR}}%</td>
                <td>{{BSC}}%</td>
                <td>{{WPS}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/eq}}

    <!-- ===================== SCHOLARSHIP REPORT ======================= -->
    {{#eq type 'scholarship_report'}}
    <table>
        <thead>
            <tr>
                <th>Scholarship Type</th>
                <th>Allocated Budget (PHP)</th>
                <th>Utilized Budget (PHP)</th>
            </tr>
        </thead>
        <tbody>
            {{#each billingReportData}}
            <tr>
                <td>{{scholarshipType}}</td>
                <td>{{peso allocatedBudget}}</td>
                <td>{{peso utilizedBudget}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/eq}}

{{/if}}

</body>
</html>
